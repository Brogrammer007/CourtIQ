PORT=4000

# Optional: paid balldontlie API key (free tier also supported)
BALLDONTLIE_BASE=https://api.balldontlie.io/v1
BALLDONTLIE_API_KEY=

# ESPN fetch cache TTL. Teams cache is 300s regardless.
CACHE_TTL_SECONDS=60

# Production: set to your frontend domain, e.g. https://courtiq.app
# Dev: * is fine
CORS_ORIGIN=*

# Per-IP rate limit for /api/* (requests per minute)
RATE_LIMIT_MAX=60
